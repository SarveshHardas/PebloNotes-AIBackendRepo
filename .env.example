# MongoDB Connection String (Replace <username>, <password>, and cluster details)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/peblo-notes?retryWrites=true&w=majority
# JWT Authentication Secret (Use a strong random string)
JWT_SECRET=secret_jwt_key
# Google Gemini API Key
GEMINI_API_KEY=gemini_api_key

